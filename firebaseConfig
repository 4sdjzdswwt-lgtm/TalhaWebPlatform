  apiKey: "BURAYA_KENDİ_API_KEYİNİ_YAZ",
  authDomain: "BURAYA_KENDİ_AUTH_DOMAINİNİ_YAZ",
  projectId: "BURAYA_KENDİ_PROJECT_IDNİ_YAZ",
  storageBucket: "BURAYA_KENDİ_STORAGE_BUCKETINI_YAZ",
  messagingSenderId: "BURAYA_KENDİ_MESSAGING_SENDER_IDNİ_YAZ",
  appId: "BURAYA_KENDİ_APP_IDNİ_YAZ"
